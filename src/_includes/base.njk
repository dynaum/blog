{%- set lang = lang or "en" -%}
{%- set s = strings[lang] -%}
{%- set transKey = translationKey or page.fileSlug -%}
{%- set langVersions = collections.localized | translations(transKey) -%}
{%- set homeUrl = "/" if lang == "en" else "/" + lang + "/" -%}
<!doctype html>
<html lang="{{ s.htmlLocale }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-B82HRZ9PJ8"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());

    gtag('config', 'G-B82HRZ9PJ8');
  </script>

  <title>{% if title %}{{ title }} — {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="author" content="{{ site.author }}">
  <meta name="theme-color" content="#0c0e10">

  <meta property="og:title" content="{{ title or site.title }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="{{ 'article' if tags and 'posts' in tags else 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:locale" content="{{ s.ogLocale }}">
  {% if cover %}<meta property="og:image" content="{{ site.url }}{{ cover }}">{% endif %}
  <meta name="twitter:card" content="{{ 'summary_large_image' if cover else 'summary' }}">
  {% if cover %}<meta name="twitter:image" content="{{ site.url }}{{ cover }}">{% endif %}

  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {%- if langVersions | length > 1 %}
  {%- for v in langVersions %}
  <link rel="alternate" hreflang="{{ strings[v.data.lang].htmlLocale }}" href="{{ site.url }}{{ v.url }}">
  {%- if v.data.lang == "en" %}
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ v.url }}">
  {%- endif %}
  {%- endfor %}
  {%- endif %}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="site-header">
    <div class="container site-header__inner">
      <a class="brand" href="{{ homeUrl }}" aria-label="dynaum blog — home">
        <span class="brand__mark" aria-hidden="true">ER</span>
        <span class="brand__prompt">elber<span class="dim">@</span>dynaum<span class="dim">:~/blog$</span></span>
      </a>
      <nav class="site-nav" aria-label="Primary">
        <a href="{{ homeUrl }}"><span class="dim">cd </span>posts</a>
        <a href="https://dynaum.com"><span class="dim">cd </span>~</a>
        {%- if langVersions | length > 1 %}
        <span class="lang-switch" aria-label="Language">
        {%- for v in langVersions %}
          {%- if not loop.first %}<span class="dim"> · </span>{% endif -%}
          {%- if v.data.lang == lang %}<span class="lang-switch__on">{{ strings[v.data.lang].langLabel }}</span>
          {%- else %}<a href="{{ v.url }}">{{ strings[v.data.lang].langLabel }}</a>{%- endif -%}
        {%- endfor %}
        </span>
        {%- endif %}
      </nav>
    </div>
  </header>

  <main id="main">
    <div class="container">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="site-footer__inner">
        <p>© {% year %} {{ site.author }} <span class="dim">·</span> written with AI, kept honest by hand</p>
        <p><a href="https://dynaum.com">dynaum.com</a> <span class="dim">·</span> <a href="https://github.com/dynaum">github</a></p>
      </div>
      <p class="site-footer__note">This site uses Google Analytics to measure traffic. It sets cookies in your browser.</p>
    </div>
  </footer>
</body>
</html>
