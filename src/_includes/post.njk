---
layout: base.njk
---
<article class="post">
  <div class="rule-row">
    <span class="rule-row__bullet">●</span>
    <span class="rule-row__label">post</span>
    <span class="rule-row__line"></span>
    <time class="rule-row__meta" datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
  </div>

  <h1 class="post__title">{{ title }}</h1>
  {% if subtitle %}<p class="post__subtitle">{{ subtitle }}</p>{% endif %}

  {% if cover %}
  <figure class="post__cover">
    <img src="{{ cover }}" alt="{{ coverAlt or title }}" width="1344" height="768" loading="eager" decoding="async">
  </figure>
  {% endif %}

  <div class="prose">
    {{ content | safe }}
  </div>

  <p class="post__back"><a href="/"><span class="dim">cd </span>../ <span class="dim">— all posts</span></a></p>
</article>
